# Template only. Copy to .env.local or inject values through a secret manager.
APP_ENV=development
LOG_LEVEL=INFO
SERVER_IP=0.0.0.0
SERVER_PORT=8000
DATABASE_URL=postgresql+asyncpg://mmbot:change-me@postgres:5432/mmbot
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=change-me
JWT_SECRET=${JWT_SECRET}
TELEGRAM_BOT_TOKEN=change-me
TELEGRAM_CHAT_ID=change-me
EXCHANGE_API_KEYS={"example_exchange":"change-me"}
EXCHANGE_API_SECRETS={"example_exchange":"change-me"}
EXCHANGE_API_PASSPHRASES={"example_exchange":"change-me"}
EXCHANGE_API_MEMOS={"example_exchange":"change-me"}
POSTGRES_DB=mmbot
POSTGRES_USER=mmbot
POSTGRES_PASSWORD=change-me
NGINX_PORT=8080
PROMETHEUS_PORT=9090
TRADING_MODE=paper
MARKET_DATA_CONNECT_ON_START=true
MARKET_DATA_EXCHANGES=binance
MARKET_DATA_SYMBOLS=BTC/USDT
MARKET_DATA_STREAMS=orderbook,trades,ticker,kline
MARKET_DATA_PERSIST_EVERY_N_MESSAGES=1
MARKET_MAKER_REFRESH_SECONDS=5
RECONCILIATION_INTERVAL_SECONDS=60
PAPER_STARTING_CASH=100000
PAPER_BASE_ASSET=BTC
PAPER_QUOTE_ASSET=USDT
